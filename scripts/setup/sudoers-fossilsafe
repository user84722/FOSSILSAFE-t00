# /etc/sudoers.d/fossilsafe
# FossilSafe service user permissions for NFS and external media operations
# Install: sudo cp deploy/sudoers-fossilsafe /etc/sudoers.d/ && sudo chmod 440 /etc/sudoers.d/fossilsafe

# NFS/CIFS mount operations - restricted to /mnt/fossilsafe/
# We enforce the destination prefix and allow common mount options.
# Note: Options are restricted in the backend, but we provide broad patterns here for flexibility 
# with the recommendation to use nosuid,nodev in the backend calls.
fossilsafe ALL=(root) NOPASSWD: /usr/bin/mount -t nfs -o *nosuid,nodev* *:/vol/* /mnt/fossilsafe/nfs/*
fossilsafe ALL=(root) NOPASSWD: /usr/bin/mount -t nfs4 -o *nosuid,nodev* *:/vol/* /mnt/fossilsafe/nfs/*
fossilsafe ALL=(root) NOPASSWD: /usr/bin/mount -t cifs -o *nosuid,nodev* //* /mnt/fossilsafe/smb/*

# Unmount operations - restricted to FossilSafe managed mount points
fossilsafe ALL=(root) NOPASSWD: /usr/bin/umount /mnt/fossilsafe/nfs/*
fossilsafe ALL=(root) NOPASSWD: /usr/bin/umount /mnt/fossilsafe/smb/*
fossilsafe ALL=(root) NOPASSWD: /usr/bin/umount /mnt/ltfs*

# Tape/LTFS operations
fossilsafe ALL=(root) NOPASSWD: /usr/bin/ltfs -o devname=* /mnt/ltfs*
fossilsafe ALL=(root) NOPASSWD: /usr/bin/mkltfs -d *
fossilsafe ALL=(root) NOPASSWD: /usr/bin/ltfsck *

# External media - restricted to read-only or nosuid
fossilsafe ALL=(root) NOPASSWD: /usr/bin/mount -o *nosuid,nodev* /dev/sd[a-z][0-9] /mnt/fossilsafe/external/*
fossilsafe ALL=(root) NOPASSWD: /usr/bin/mount -o *nosuid,nodev* /dev/nvme[0-9]n[0-9]p[0-9] /mnt/fossilsafe/external/*
