# FossilSafe sudoers configuration
# Allows the fossilsafe service user to run tape operations without password

# Tape device operations
fossilsafe ALL=(root) NOPASSWD: /usr/bin/mtx
fossilsafe ALL=(root) NOPASSWD: /usr/sbin/mtx
fossilsafe ALL=(root) NOPASSWD: /bin/mt
fossilsafe ALL=(root) NOPASSWD: /usr/bin/mt
fossilsafe ALL=(root) NOPASSWD: /usr/bin/sg_inq
fossilsafe ALL=(root) NOPASSWD: /sbin/modprobe fuse
fossilsafe ALL=(root) NOPASSWD: /usr/bin/lsscsi

# Mounting/unmounting LTFS
fossilsafe ALL=(root) NOPASSWD: /usr/bin/mkltfs
fossilsafe ALL=(root) NOPASSWD: /usr/local/bin/mkltfs
fossilsafe ALL=(root) NOPASSWD: /usr/bin/ltfs
fossilsafe ALL=(root) NOPASSWD: /usr/local/bin/ltfs
fossilsafe ALL=(root) NOPASSWD: /usr/bin/ltfsck
fossilsafe ALL=(root) NOPASSWD: /usr/local/bin/ltfsck

# System utilities
fossilsafe ALL=(root) NOPASSWD: /bin/mount
fossilsafe ALL=(root) NOPASSWD: /bin/umount
fossilsafe ALL=(root) NOPASSWD: /usr/bin/fusermount3
fossilsafe ALL=(root) NOPASSWD: /usr/bin/fusermount

# Device discovery
fossilsafe ALL=(root) NOPASSWD: /usr/bin/lsblk
fossilsafe ALL=(root) NOPASSWD: /bin/lsblk
fossilsafe ALL=(root) NOPASSWD: /usr/sbin/udevadm
fossilsafe ALL=(root) NOPASSWD: /sbin/udevadm

# Logging and diagnostics
fossilsafe ALL=(root) NOPASSWD: /usr/bin/sg_ses
fossilsafe ALL=(root) NOPASSWD: /usr/bin/sg_logs
fossilsafe ALL=(root) NOPASSWD: /usr/bin/smartctl
fossilsafe ALL=(root) NOPASSWD: /usr/sbin/smartctl
